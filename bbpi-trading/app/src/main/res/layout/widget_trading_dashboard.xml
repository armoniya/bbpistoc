<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_widget_container"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Top Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:id="@+id/header_left"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_widget_symbol"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SOL/USDT"
                android:textColor="#F1EEF7"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_widget_tf"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_widget_badge"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:text="15m"
                android:textColor="#A29CB4"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_widget_bbpi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_widget_badge"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:text="BBPI 46"
                android:textColor="#FFD24A"
                android:textSize="11sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btn_widget_refresh"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Yenile"
                android:padding="4dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_refresh_white" />
        </LinearLayout>
    </RelativeLayout>

    <!-- Main Content Grid -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:baselineAligned="false"
        android:orientation="horizontal">

        <!-- Left Readout (Price + Delta) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_widget_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="77.41"
                android:textColor="#F1EEF7"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_widget_delta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_widget_chip_up"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:text="▲ +2.45%"
                android:textColor="#FFD24A"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Right Readout (Position Box) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_widget_badge"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:padding="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="POZİSYON"
                    android:textColor="#645C74"
                    android:textSize="9sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_widget_pos_side"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="YOK"
                    android:textColor="#A29CB4"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_widget_pnl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="—"
                android:textColor="#645C74"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_widget_pos_sub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="işlem yok"
                android:textColor="#645C74"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Footer timestamp -->
    <TextView
        android:id="@+id/tv_widget_updated"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Son Güncelleme: —"
        android:textColor="#645C74"
        android:textSize="10sp" />
</LinearLayout>
